# Supabase Auth and Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Models
ANTHROPIC_API_KEY=sk-ant-v1-xxx  # Required - https://console.anthropic.com/

# Optional AI Providers (for future fallbacks)
OPENAI_API_KEY=sk-proj-xxx
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# Data Source Integrations (optional)
CRUNCHBASE_API_KEY=xxx
CORESIGNAL_API_KEY=xxx
PROXYCURL_API_KEY=xxx
OPENCLAY_API_KEY=xxx

# Enrichment Integrations (optional)
FIRECRAWL_API_KEY=xxx

# CRM Integrations (optional)
HUBSPOT_CLIENT_ID=xxx
HUBSPOT_CLIENT_SECRET=xxx
SALESFORCE_CLIENT_ID=xxx
SALESFORCE_CLIENT_SECRET=xxx

# App Configuration
APP_URL=http://localhost:3000